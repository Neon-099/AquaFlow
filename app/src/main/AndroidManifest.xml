<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
            android:allowBackup="true"
            android:dataExtractionRules="@xml/data_extraction_rules"
            android:fullBackupContent="@xml/backup_rules"
            android:icon="@mipmap/aq_logo_launcher"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/aq_logo_launcher"
            android:supportsRtl="true"
            android:theme="@style/Theme.AquaFlow"
            android:usesCleartextTraffic="true"
            >

        <meta-data
                android:name="com.google.firebase.messaging.default_notification_icon"
                android:resource="@drawable/aq_notification" />
        <meta-data
                android:name="com.google.firebase.messaging.default_notification_color"
                android:resource="@color/logo_color" />

        <service
                android:name=".utils.AquaFlowFirebaseMessagingService"
                android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <activity
                android:name=".AuthPage"
                android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".HomePage" android:exported="false" />
        <activity android:name=".OrderPage" android:exported="false" />
        <activity android:name=".MessagePage" android:exported="false" />
        <activity android:name=".NotificationPage" android:exported="false" />
        <activity android:name=".ChatPage" android:exported="false" />
        <activity android:name=".OrderTrackingPage" android:exported="false" />
        <activity android:name=".OrderFormPage" android:exported="false" />
        <activity android:name=".ForgotPasswordPage" android:exported="false" />
        <activity android:name=".ProfilePage" android:exported="false" />
        <activity android:name=".RiderOrderPage" android:exported="false" />
        <activity android:name=".RiderMessagePage" android:exported="false" />
        <activity android:name=".RiderProfilePage" android:exported="false" />
        <activity android:name=".RiderHomePage" android:exported="false" />
    </application>
</manifest>
